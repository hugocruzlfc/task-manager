{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"pnpm --dir frontend dev\" \"pnpm --dir backend start:dev\"",
    "install:all": "pnpm install && cd frontend && pnpm install && cd ../backend && pnpm install  && cd ..",
    "lint:all": "pnpm --dir frontend lint && pnpm --dir backend lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,html,json}": "prettier --write"
  }
}
