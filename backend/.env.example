# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://task_user:task_password@localhost:5432/task_manager"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
# ¡Cambia estos valores en producción! Mínimo 16 caracteres.
JWT_ACCESS_SECRET="super_access_secret_change_me"
JWT_REFRESH_SECRET="super_refresh_secret_change_me"

ACCESS_TOKEN_EXPIRATION="15m"
REFRESH_TOKEN_EXPIRATION="7d"
